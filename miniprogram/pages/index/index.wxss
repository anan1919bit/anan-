page {
  background: linear-gradient(180deg, #f7f8fc 0%, #eef3ff 100%);
}

.shop-page {
  padding: 28rpx 24rpx 210rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 236, 0.45) 0, rgba(255, 214, 236, 0) 32%),
    radial-gradient(circle at top left, rgba(179, 208, 255, 0.3) 0, rgba(179, 208, 255, 0) 28%);
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 42rpx 34rpx 36rpx;
  border-radius: 42rpx;
  color: #ffffff;
  box-shadow: 0 32rpx 80rpx rgba(89, 102, 201, 0.28);
  margin-bottom: 32rpx;
  background: #4d63ff;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(145deg, rgba(28, 28, 46, 0.62) 0%, rgba(72, 89, 185, 0.26) 54%, rgba(255, 214, 230, 0.16) 100%);
}

.hero-card::after {
  content: "";
  position: absolute;
  z-index: 1;
  right: -30rpx;
  top: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.hero-badge {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  font-size: 20rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 10rpx 28rpx rgba(16, 18, 35, 0.12);
}

.hero-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.22);
}

.hero-title {
  position: relative;
  z-index: 1;
  font-size: 56rpx;
  line-height: 1.26;
  font-weight: 700;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.28);
}

.hero-desc {
  position: relative;
  z-index: 1;
  font-size: 27rpx;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.94);
  margin-bottom: 30rpx;
  text-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.22);
}

.hero-actions {
  position: relative;
  z-index: 1;
  margin-bottom: 26rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.hero-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 192rpx;
  height: 72rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  backdrop-filter: blur(16rpx);
  box-shadow: 0 16rpx 36rpx rgba(17, 20, 37, 0.18);
}

.hero-action-btn-light {
  background: rgba(255, 255, 255, 0.12);
}

.hero-metrics {
  display: flex;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.metric-item {
  flex: 1;
  padding: 22rpx 0 18rpx;
  text-align: center;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(16rpx);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.24);
}

.metric-value {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.18);
}

.metric-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.82);
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.category-pill {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  min-width: 228rpx;
  padding: 26rpx 24rpx;
  margin-right: 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(223, 228, 255, 0.8);
  box-shadow: 0 18rpx 40rpx rgba(34, 47, 91, 0.08);
  transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.32s cubic-bezier(0.22, 1, 0.36, 1), background 0.28s ease, color 0.28s ease;
}

.category-pill-active {
  background: linear-gradient(135deg, #2f3554 0%, #667bff 100%);
  transform: translateY(-6rpx);
  box-shadow: 0 24rpx 48rpx rgba(78, 102, 255, 0.24);
}

.category-pill-active .category-name,
.category-pill-active .category-desc {
  color: #ffffff;
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d2238;
  margin-bottom: 8rpx;
}

.category-desc {
  font-size: 20rpx;
  color: #7b8095;
  line-height: 1.5;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  transform: translateY(0);
  opacity: 1;
  transition: opacity 0.22s ease, transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}

.product-list-ready .product-card {
  animation: cardFadeIn 0.42s cubic-bezier(0.22, 1, 0.36, 1);
}

.product-list-switching {
  opacity: 0.18;
  transform: translateY(18rpx) scale(0.985);
}

.product-card {
  border-radius: 38rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(228, 233, 255, 0.9);
  box-shadow: 0 24rpx 52rpx rgba(31, 40, 75, 0.08);
  transform: translateZ(0);
  transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.32s cubic-bezier(0.22, 1, 0.36, 1);
}

.product-main {
  display: flex;
  gap: 22rpx;
  align-items: stretch;
}

.product-cover {
  width: 204rpx;
  min-height: 228rpx;
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.5), 0 14rpx 30rpx rgba(76, 96, 187, 0.12);
}

.cover-ring {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  top: 30rpx;
  left: 36rpx;
}

.cover-dot {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  right: 34rpx;
  top: 34rpx;
}

.cover-name {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
  text-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.18);
}

.product-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.product-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  color: #30354a;
  font-size: 20rpx;
}

.product-rating {
  font-size: 22rpx;
  color: #6f7489;
}

.product-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d2238;
  margin-bottom: 12rpx;
}

.product-desc {
  font-size: 22rpx;
  line-height: 1.7;
  color: #6f7489;
  margin-bottom: auto;
}

.product-footer {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-wrap {
  color: #1d2238;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.price-value {
  font-size: 42rpx;
  font-weight: 700;
}

.buy-btn {
  min-width: 176rpx;
  text-align: center;
  padding: 20rpx 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2e3450 0%, #6a7fff 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 32rpx rgba(79, 103, 255, 0.24);
  transition: transform 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
}

.stepper {
  display: flex;
  align-items: center;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  animation: stepperPop 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}

.stepper-btn {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 54rpx;
  font-size: 30rpx;
  color: #2c3145;
  background: #ffffff;
}

.stepper-btn-primary {
  background: linear-gradient(135deg, #20263c 0%, #4f67ff 100%);
  color: #ffffff;
}

.stepper-count {
  min-width: 48rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #23283b;
  padding: 0 14rpx;
}

.bag-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 26rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(232, 237, 255, 0.95);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 28rpx 68rpx rgba(30, 39, 73, 0.16);
  transform: translateY(0) scale(1);
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
}

.bag-bar-active {
  box-shadow: 0 28rpx 70rpx rgba(73, 96, 255, 0.2);
}

.bag-bar-pulse {
  animation: bagPulse 0.42s cubic-bezier(0.22, 1, 0.36, 1);
}

.bag-info {
  display: flex;
  align-items: center;
}

.bag-icon-wrap {
  position: relative;
  margin-right: 20rpx;
}

.bag-icon {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #20263c 0%, #4f67ff 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.bag-count {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff6b6b;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
}

.bag-title {
  font-size: 28rpx;
  color: #1f2437;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.bag-subtitle {
  font-size: 20rpx;
  color: #7b8095;
}

.checkout-btn {
  min-width: 160rpx;
  text-align: center;
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #20263c 0%, #4f67ff 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.checkout-btn-disabled {
  opacity: 0.45;
}

.toast {
  position: fixed;
  left: 50%;
  bottom: 156rpx;
  transform: translateX(-50%);
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(22, 27, 45, 0.88);
  color: #ffffff;
  font-size: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(22, 27, 45, 0.18);
}

.toast-enter {
  animation: toastRise 0.32s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes cardFadeIn {
  0% {
    opacity: 0;
    transform: translateY(20rpx) scale(0.985);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes stepperPop {
  0% {
    opacity: 0;
    transform: scale(0.86);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes bagPulse {
  0% {
    transform: translateY(0) scale(1);
  }
  40% {
    transform: translateY(-4rpx) scale(1.03);
  }
  100% {
    transform: translateY(0) scale(1);
  }
}

@keyframes toastRise {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(22rpx) scale(0.94);
  }
  100% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
}
