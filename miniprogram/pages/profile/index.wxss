page {
  background: linear-gradient(180deg, #f6f8ff 0%, #eef3ff 100%);
}

.profile-page {
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.profile-hero {
  padding: 32rpx 28rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #1f2437 0%, #4d63ff 60%, #8fa1ff 100%);
  color: #ffffff;
  box-shadow: 0 24rpx 56rpx rgba(76, 100, 255, 0.18);
  margin-bottom: 24rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.user-main {
  display: flex;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  margin-right: 20rpx;
}

.user-meta {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.level {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.92);
  font-size: 20rpx;
}

.login-btn {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 22rpx;
  backdrop-filter: blur(10rpx);
}

.stats-row {
  display: flex;
  gap: 18rpx;
}

.stat-card {
  flex: 1;
  border-radius: 24rpx;
  padding: 20rpx 0;
  text-align: center;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(12rpx);
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.84);
}

.section-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 30rpx;
  padding: 26rpx 24rpx;
  box-shadow: 0 18rpx 40rpx rgba(35, 49, 98, 0.08);
  margin-bottom: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2033;
}

.section-more {
  font-size: 22rpx;
  color: #7f879a;
}

.order-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.order-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-icon-wrap {
  position: relative;
  margin-bottom: 14rpx;
}

.order-icon {
  width: 78rpx;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #eef2ff 0%, #dde5ff 100%);
  color: #445bff;
  font-size: 28rpx;
  font-weight: 700;
}

.order-count {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  min-width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff6b6b;
  color: #ffffff;
  font-size: 18rpx;
  text-align: center;
}

.order-label {
  font-size: 22rpx;
  color: #2a3045;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #f2f4fa;
}

.service-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.service-content {
  flex: 1;
}

.service-title {
  font-size: 28rpx;
  color: #1d2338;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7f879a;
}

.service-arrow {
  color: #b2b8c7;
  font-size: 34rpx;
  margin-left: 18rpx;
}
